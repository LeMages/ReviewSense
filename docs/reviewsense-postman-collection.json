{
  "info": {
    "name": "ReviewSense - Demo",
    "description": "Collection de démo pour l'API ReviewSense (authentification, reviews, endpoint externe et GraphQL).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Reviews API",
      "item": [
        {
          "name": "Submit Review",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"This product exceeded all my expectations. The quality is outstanding!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/reviews",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "reviews"]
            }
          },
          "response": []
        },
        {
          "name": "Get My Reviews",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/reviews",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "reviews"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "External API (Demo)",
      "item": [
        {
          "name": "Predict WITH JWT ✅",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Terrible product, broke after one day. Total waste of money.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/external/predict",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "external", "predict"]
            }
          },
          "response": []
        },
        {
          "name": "Predict WITHOUT JWT ❌",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Terrible product\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/external/predict",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "external", "predict"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "GraphQL",
      "item": [
        {
          "name": "Sentiment Stats",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"{ reviewStats { positive negative neutral total } }\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": ["{{baseUrl}}"],
              "path": ["graphql"]
            }
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://main-api-production-6541.up.railway.app"
    },
    {
      "key": "jwt_token",
      "value": ""
    }
  ]
}
